<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package = "com.js.arquictecturajava.bo">
    <class name = "com.js.arquictecturajava.Libros" table = "Libros">
        <id name = "isbn" type = "string" />
        <property name = "titulo" type = "string" column = "titulo" />
        <property name = "categoria" type = "string" column="categoria" />
    </class>
</hibernate-mapping>